# Threadwise product analytics (PostHog EU Cloud)
# The project token is safe to use for ingestion, but keep your actual value in
# a local .env file. Never add a PostHog personal API key here.
POSTHOG_PROJECT_TOKEN=phc_replace_with_your_project_token
POSTHOG_HOST=https://eu.i.posthog.com

# Production analytics is opt-in. Development and tests stay offline by default.
THREADWISE_ANALYTICS_ENABLED=false
THREADWISE_ENVIRONMENT=development

# Enable only for the explicit synthetic validation command in the README.
THREADWISE_ANALYTICS_ALLOW_SYNTHETIC=false
