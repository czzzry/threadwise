{
  "manifest_version": 3,
  "name": "Email Agent Gmail Companion",
  "version": "0.1.0",
  "description": "Shows the Email Agent companion sidebar inside Gmail using the local companion server.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:8021/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Email Agent Gmail Companion"
  }
}
